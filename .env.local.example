# Copy to .env.local and fill in. Never commit real secrets to this file.

# Supabase (from your project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (server-side only)
OPENAI_API_KEY=

# Resend (for email reminders) — optional for local dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=Lexora <onboarding@resend.dev>

# Cron auth — any random string; pass it as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=replace-with-random-string

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
